    "Ms2DashpipelineDashdev": {
      "Type": "AWS::StepFunctions::StateMachine",
      "Properties": {
        "DefinitionString": "{\n  \"Comment\": \"Pipeline MS2: S3 Clone -> Orchestrator -> Webhook\",\n  \"StartAt\": \"Initialize\",\n  \"QueryLanguage\": \"JSONata\",\n  \"States\": {\n    \"Initialize\": {\n      \"Type\": \"Pass\",\n      \"Assign\": {\n        \"jobId\": \"{% $states.input.jobId %}\",\n        \"repoUrl\": \"{% $states.input.repoUrl %}\",\n        \"commitSha\": \"{% $states.input.commitSha %}\",\n        \"webhookUrl\": \"{% $states.input.webhookUrl %}\",\n        \"s3Prefix\": \"{% 'repos/' & $states.input.jobId & '/' & $states.input.commitSha %}\"\n      },\n      \"Next\": \"Pull Repo to S3\"\n    },\n    \"Pull Repo to S3\": {\n      \"Type\": \"Task\",\n      \"Resource\": \"arn:aws:states:::lambda:invoke\",\n      \"Arguments\": {\n        \"FunctionName\": \"arn:aws:lambda:eu-central-1:503104739946:function:ms2-analysis-service-dev-pullRepoToS3\",\n        \"Payload\": {\n          \"jobId\": \"{% $jobId %}\",\n          \"repoUrl\": \"{% $repoUrl %}\",\n          \"commitSha\": \"{% $commitSha %}\",\n          \"s3Prefix\": \"{% $s3Prefix %}\"\n        }\n      },\n      \"Assign\": {\n        \"s3Bucket\": \"{% $states.result.Payload.s3Bucket %}\",\n        \"s3Key\": \"{% $states.result.Payload.s3Key %}\",\n        \"repoMetadata\": \"{% $states.result.Payload.repoMetadata %}\"\n      },\n      \"Next\": \"Run Orchestrator\"\n    },\n    \"Run Orchestrator\": {\n      \"Type\": \"Task\",\n      \"Resource\": \"arn:aws:states:::lambda:invoke\",\n      \"Arguments\": {\n        \"FunctionName\": \"arn:aws:lambda:eu-central-1:503104739946:function:ms2-analysis-service-dev-orchestrator\",\n        \"Payload\": {\n          \"s3Bucket\": \"{% $s3Bucket %}\",\n          \"s3Key\": \"{% $s3Key %}\",\n          \"isRelease\": \"{% $count($repoMetadata.tags) > 0 or $repoMetadata.hasChangelog %}\",\n          \"orchestratorRaw\": \"{% 'Metadati Repo: ' & $string($repoMetadata) %}\"\n        }\n      },\n      \"Assign\": {\n        \"finalReport\": \"{% $states.result.Payload %}\"\n      },\n      \"Next\": \"Notify Webhook\"\n    },\n    \"Notify Webhook\": {\n      \"Type\": \"Task\",\n      \"Resource\": \"arn:aws:states:::lambda:invoke\",\n      \"Arguments\": {\n        \"FunctionName\": \"arn:aws:lambda:eu-central-1:503104739946:function:ms2-analysis-service-dev-webhookSender\",\n        \"Payload\": {\n          \"webhookUrl\": \"{% $webhookUrl %}\",\n          \"report\": \"{% $finalReport %}\"\n        }\n      },\n      \"Next\": \"Success\"\n    },\n    \"Success\": {\n      \"Type\": \"Succeed\"\n    }\n  }\n}",
        "RoleArn": {
          "Fn::GetAtt": [
            "Ms2DashpipelineDashdevRole",
            "Arn"
          ]
        },
        "StateMachineName": "ms2-pipeline-dev"
      },
      "DependsOn": [
        "Ms2DashpipelineDashdevRole"
      ]
    },
