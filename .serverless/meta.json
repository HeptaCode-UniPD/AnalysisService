    },
    "serviceRawFile": "service: ms2-analysis-service\n\nprovider:\n  name: aws\n  runtime: nodejs20.x\n  region: eu-central-1\n  memorySize: 512\n  iamRoleStatements:\n    # Permesso per scrivere su S3 (per la Lambda pullRepo)\n    - Effect: Allow\n      Action:\n        - s3:PutObject\n      Resource:\n        - !Join ['', [!GetAtt RepositoryBucket.Arn, '/*']]\n    # Permesso per il Wrapper NestJS di avviare la Step Function\n    - Effect: Allow\n      Action:\n        - states:StartExecution\n      Resource:\n        - !Sub \"arn:aws:states:${AWS::Region}:${AWS::AccountId}:stateMachine:ms2-pipeline-${sls:stage}\"\n    # Permesso all'Orchestratore di chiamare gli Agenti AI\n    - Effect: Allow\n      Action:\n        - lambda:InvokeFunction\n      Resource: \"*\"\n\npackage:\n  individually: false\n  patterns:\n    - '!src/**'\n    - '!test/**'\n    - '!.github/**'\n    - 'dist/**'\n    - 'node_modules/**'\n\nbuild:\n  esbuild: false\n\nplugins:\n  - serverless-step-functions\n  - serverless-offline\n\nfunctions:\n  wrapperAdapter:\n    handler: dist/wrapper/handler.startAnalysis\n    environment:\n      # Passiamo l'ARN dinamico della Step Function al codice NestJS\n      STATE_MACHINE_ARN: !Sub \"arn:aws:states:${AWS::Region}:${AWS::AccountId}:stateMachine:ms2-pipeline-${sls:stage}\"\n    events:\n      - http:\n          path: /analyze\n          method: post\n\n  pullRepoToS3:\n    handler: dist/lambdas/pull-repo.handler\n    timeout: 60\n    memorySize: 1024\n    environment:\n      S3_BUCKET_NAME: !Ref RepositoryBucket\n    layers:\n      - arn:aws:lambda:eu-central-1:553035198032:layer:git-lambda2:8\n  \n  webhookSender:\n    handler: dist/lambdas/webhook.handler\n    timeout: 15\n  \n  orchestrator:\n    handler: dist/lambdas/orchestrator.lambda.orchestratorHandler\n    timeout: 300 # Diamo 5 minuti di tempo perché Claude deve leggere tutto!\n    environment:\n      # Passiamo i nomi esatti delle funzioni generate da Serverless Framework\n      LAMBDA_OWASP_NAME: ms2-analysis-service-${sls:stage}-owaspAgent\n      LAMBDA_TEST_NAME: ms2-analysis-service-${sls:stage}-testAgent\n      LAMBDA_DOCS_NAME: ms2-analysis-service-${sls:stage}-docsAgent\n\n  owaspAgent:\n    handler: dist/lambdas/owasp-agent.lambda.owaspAgentHandler\n    timeout: 300\n\n  testAgent:\n    handler: dist/lambdas/test-agent.lamdbda.testAgentHandler\n    timeout: 300\n\n  docsAgent:\n    handler: dist/lambdas/docs-agent.lambda.docAgentHandler\n    timeout: 300\n\n# Definizione della Step Function\nstepFunctions:\n  stateMachines:\n    RepoAnalysisStateMachine:\n      name: ms2-pipeline-${sls:stage}\n      definition: ${file(state-machine.json)} \n\n# Creazione del Bucket S3\nresources:\n  Resources:\n    RepositoryBucket:\n      Type: AWS::S3::Bucket\n      Properties:\n        BucketName: ms2-analysis-repos-bucket-${sls:stage}-${aws:accountId}\n        LifecycleConfiguration:\n          Rules:\n            - Id: AutoDeleteOldZips\n              Status: Enabled\n              ExpirationInDays: 1",
    "command": [
      "logs"
    ],
    "options": {
      "function": "wrapperAdapter"
    },
