{
  "/Users/albertoreginato/Documents/AnalysisService/serverless.yml": {
    "versionFramework": "4.33.0",
    "servicePath": "/Users/albertoreginato/Documents/AnalysisService/serverless.yml",
    "serviceConfigFileName": "serverless.yml",
    "service": {
      "service": "ms2-analysis-service",
      "provider": {
        "name": "aws",
        "runtime": "nodejs20.x",
        "region": "eu-central-1",
        "memorySize": 512,
        "iamRoleStatements": [
          {
            "Effect": "Allow",
            "Action": [
              "s3:PutObject"
            ],
            "Resource": [
              {
                "Fn::Join": [
                  "",
                  [
                    {
                      "Fn::GetAtt": [
                        "RepositoryBucket",
                        "Arn"
                      ]
                    },
                    "/*"
                  ]
                ]
              }
            ]
          },
          {
            "Effect": "Allow",
            "Action": [
              "states:StartExecution"
            ],
            "Resource": [
              {
                "Fn::Sub": "arn:aws:states:${AWS::Region}:${AWS::AccountId}:stateMachine:ms2-pipeline-dev"
              }
            ]
          },
          {
            "Effect": "Allow",
            "Action": [
              "lambda:InvokeFunction"
            ],
            "Resource": "*"
          }
        ],
        "stage": "dev",
        "versionFunctions": true
      },
      "package": {
        "individually": false,
        "patterns": [
          "!src/**",
          "!test/**",
          "!.github/**",
          "dist/**",
          "node_modules/**"
        ],
        "artifactsS3KeyDirname": "serverless/ms2-analysis-service/dev/code-artifacts"
      },
      "build": {
        "esbuild": false
      },
      "plugins": [
        "serverless-step-functions",
        "serverless-offline"
      ],
      "functions": {
        "wrapperAdapter": {
          "handler": "dist/wrapper/handler.startAnalysis",
          "environment": {
            "STATE_MACHINE_ARN": {
              "Fn::Sub": "arn:aws:states:${AWS::Region}:${AWS::AccountId}:stateMachine:ms2-pipeline-dev"
            }
          },
          "events": [
            {
              "http": {
                "path": "/analyze",
                "method": "post"
              }
            }
          ],
          "name": "ms2-analysis-service-dev-wrapperAdapter"
        },
        "pullRepoToS3": {
          "handler": "dist/lambdas/pull-repo.handler",
          "timeout": 60,
          "memorySize": 1024,
          "environment": {
            "S3_BUCKET_NAME": {
              "Ref": "RepositoryBucket"
            }
          },
          "layers": [
            "arn:aws:lambda:eu-central-1:553035198032:layer:git-lambda2:8"
          ],
          "events": [],
          "name": "ms2-analysis-service-dev-pullRepoToS3"
        },
        "webhookSender": {
          "handler": "dist/lambdas/webhook.handler",
          "timeout": 15,
          "events": [],
          "name": "ms2-analysis-service-dev-webhookSender"
        },
        "orchestrator": {
          "handler": "dist/lambdas/orchestrator.lambda.orchestratorHandler",
          "timeout": 300,
          "environment": {
            "LAMBDA_OWASP_NAME": "ms2-analysis-service-dev-owaspAgent",
            "LAMBDA_TEST_NAME": "ms2-analysis-service-dev-testAgent",
            "LAMBDA_DOCS_NAME": "ms2-analysis-service-dev-docsAgent"
          },
          "events": [],
          "name": "ms2-analysis-service-dev-orchestrator"
        },
        "owaspAgent": {
          "handler": "dist/lambdas/owasp-agent.lambda.owaspAgentHandler",
          "timeout": 300,
          "events": [],
          "name": "ms2-analysis-service-dev-owaspAgent"
        },
        "testAgent": {
          "handler": "dist/lambdas/test-agent.lamdbda.testAgentHandler",
          "timeout": 300,
          "events": [],
          "name": "ms2-analysis-service-dev-testAgent"
        },
        "docsAgent": {
          "handler": "dist/lambdas/docs-agent.lambda.docAgentHandler",
          "timeout": 300,
          "events": [],
          "name": "ms2-analysis-service-dev-docsAgent"
        }
      },
      "stepFunctions": {
        "stateMachines": {
          "RepoAnalysisStateMachine": {
            "name": "ms2-pipeline-dev",
            "definition": {
              "Comment": "Pipeline MS2: S3 Clone -> Orchestrator -> Webhook",
              "StartAt": "Initialize",
              "QueryLanguage": "JSONata",
              "States": {
                "Initialize": {
                  "Type": "Pass",
                  "Assign": {
                    "jobId": "{% $states.input.jobId %}",
                    "repoUrl": "{% $states.input.repoUrl %}",
                    "commitSha": "{% $states.input.commitSha %}",
                    "webhookUrl": "{% $states.input.webhookUrl %}",
                    "s3Prefix": "{% 'repos/' & $states.input.jobId & '/' & $states.input.commitSha %}"
                  },
                  "Next": "Pull Repo to S3"
                },
                "Pull Repo to S3": {
                  "Type": "Task",
                  "Resource": "arn:aws:states:::lambda:invoke",
                  "Arguments": {
                    "FunctionName": "arn:aws:lambda:eu-central-1:503104739946:function:ms2-analysis-service-dev-pullRepoToS3",
                    "Payload": {
                      "jobId": "{% $jobId %}",
                      "repoUrl": "{% $repoUrl %}",
                      "commitSha": "{% $commitSha %}",
                      "s3Prefix": "{% $s3Prefix %}"
                    }
                  },
                  "Assign": {
                    "s3Bucket": "{% $states.result.Payload.s3Bucket %}",
                    "s3Key": "{% $states.result.Payload.s3Key %}",
                    "repoMetadata": "{% $states.result.Payload.repoMetadata %}"
                  },
                  "Next": "Run Orchestrator"
                },
                "Run Orchestrator": {
                  "Type": "Task",
                  "Resource": "arn:aws:states:::lambda:invoke",
                  "Arguments": {
                    "FunctionName": "arn:aws:lambda:eu-central-1:503104739946:function:ms2-analysis-service-dev-orchestrator",
                    "Payload": {
                      "s3Bucket": "{% $s3Bucket %}",
                      "s3Key": "{% $s3Key %}",
                      "isRelease": "{% $count($repoMetadata.tags) > 0 or $repoMetadata.hasChangelog %}",
                      "orchestratorRaw": "{% 'Metadati Repo: ' & $string($repoMetadata) %}"
                    }
                  },
                  "Assign": {
                    "finalReport": "{% $states.result.Payload %}"
                  },
                  "Next": "Notify Webhook"
                },
                "Notify Webhook": {
                  "Type": "Task",
                  "Resource": "arn:aws:states:::lambda:invoke",
                  "Arguments": {
                    "FunctionName": "arn:aws:lambda:eu-central-1:503104739946:function:ms2-analysis-service-dev-webhookSender",
                    "Payload": {
                      "webhookUrl": "{% $webhookUrl %}",
                      "report": "{% $finalReport %}"
                    }
                  },
                  "Next": "Success"
                },
                "Success": {
                  "Type": "Succeed"
                }
              }
            }
          }
        }
      },
      "resources": {
        "Resources": {
          "RepositoryBucket": {
            "Type": "AWS::S3::Bucket",
            "Properties": {
              "BucketName": "ms2-analysis-repos-bucket-dev-503104739946",
              "LifecycleConfiguration": {
                "Rules": [
                  {
                    "Id": "AutoDeleteOldZips",
                    "Status": "Enabled",
                    "ExpirationInDays": 1
                  }
                ]
              }
            }
          }
        }
      }
    },
    "provider": {
      "name": "aws",
      "runtime": "nodejs20.x",
      "region": "eu-central-1",
      "memorySize": 512,
      "iamRoleStatements": [
        {
          "Effect": "Allow",
          "Action": [
            "s3:PutObject"
          ],
          "Resource": [
            {
              "Fn::Join": [
                "",
