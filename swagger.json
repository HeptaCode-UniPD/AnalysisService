{
  "openapi": "3.0.0",
  "paths": {
    "/analyze": {
      "post": {
        "description": "\n      Questa operazione avvia una pipeline di analisi asincrona.\n      - **Input**: URL di un repository pubblico.\n      - **Processo**: Esegue Pull Repo -> Bundling -> Analisi AI (Docs, OWASP, Test).\n      - **Output Immediato**: Conferma dell'accodamento con un jobId.\n      - **Output Finale (Webhook)**: Una volta completata (fino a 15 min), il sistema invierà una notifica POST all'URL di Webhook pre-configurato.\n      \n      Il payload inviato al Webhook seguirà lo schema 'AnalysisWebhookPayloadDto'.\n    ",
        "operationId": "AppController_startAnalysis",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnalysisRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Richiesta accettata. L'analisi è stata accodata con successo.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalysisResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Richiesta non valida. Parametri mancanti o URL non corretto."
          },
          "401": {
            "description": "API Key mancante o non valida."
          },
          "500": {
            "description": "Errore interno del server durante l'avvio della pipeline."
          }
        },
        "security": [
          {
            "x-api-key": []
          }
        ],
        "summary": "Avvia l'analisi asincrona di un repository",
        "tags": [
          "Pipeline Analysis"
        ]
      }
    }
  },
  "info": {
    "title": "Analysis Service MS2",
    "description": "API per l'analisi automatizzata di repository via AI (Docs, OWASP, Test).",
    "version": "2.0",
    "contact": {}
  },
  "tags": [],
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Locale"
    },
    {
      "url": "https://api.ms2.example.com",
      "description": "Produzione (Placeholder)"
    }
  ],
  "components": {
    "securitySchemes": {
      "x-api-key": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    },
    "schemas": {
      "AnalysisDetailDto": {
        "type": "object",
        "properties": {
          "agentName": {
            "type": "string",
            "description": "Nome dell'area o dell'agente (OWASP, TEST, DOCS)",
            "example": "OWASP"
          },
          "summary": {
            "type": "string",
            "description": "Breve sintesi dell'esito dell'analisi",
            "example": "Trovate 3 vulnerabilità critiche."
          },
          "report": {
            "type": "string",
            "description": "Report completo in formato Markdown",
            "example": "### Vulnerabilità...\n..."
          }
        },
        "required": [
          "agentName",
          "summary",
          "report"
        ]
      },
      "AnalysisWebhookPayloadDto": {
        "type": "object",
        "properties": {
          "analysisDetails": {
            "description": "Lista dei dettagli granulari per ogni area di analisi",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AnalysisDetailDto"
            }
          },
          "repoUrl": {
            "type": "string",
            "description": "URL del repository analizzato",
            "example": "https://github.com/HeptaCode-UniPD/AnalysisService.git"
          },
          "commitId": {
            "type": "string",
            "description": "ID o hash del commit analizzato",
            "example": "abcdef1234567890"
          },
          "jobId": {
            "type": "string",
            "description": "ID univoco del job di analisi",
            "example": "job-esterno-12345"
          },
          "status": {
            "type": "string",
            "description": "Stato finale della pipeline",
            "example": "done",
            "enum": [
              "done",
              "failed"
            ]
          }
        },
        "required": [
          "analysisDetails",
          "repoUrl",
          "commitId",
          "jobId",
          "status"
        ]
      },
      "AnalysisRequestDto": {
        "type": "object",
        "properties": {
          "repoUrl": {
            "type": "string",
            "description": "URL del repository GitHub/GitLab da analizzare",
            "example": "https://github.com/HeptaCode-UniPD/AnalysisService.git"
          },
          "jobId": {
            "type": "string",
            "description": "ID univoco del job fornito dal chiamante per tracciamento",
            "example": "job-esterno-12345"
          },
          "commitSha": {
            "type": "string",
            "description": "Hash del commit specifico da analizzare (opzionale)",
            "example": "abcdef1234567890"
          }
        },
        "required": [
          "repoUrl",
          "jobId"
        ]
      },
      "AnalysisResponseDto": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Messaggio di conferma dell'avvio della pipeline",
            "example": "Analisi avviata con successo"
          },
          "jobId": {
            "type": "string",
            "description": "ID univoco del job di analisi generato dal sistema",
            "example": "5f9a1b2c-3d4e-5f6g-7h8i-9j0k1l2m3n4o"
          },
          "executionArn": {
            "type": "string",
            "description": "ARN dell'esecuzione della State Machine AWS Step Functions",
            "example": "arn:aws:states:eu-central-1:123456789012:execution:ms2-pipeline-dev:5f9a1b2c-3d4e..."
          }
        },
        "required": [
          "message",
          "jobId",
          "executionArn"
        ]
      }
    }
  }
}