    return { agent: 'docs', status: 'success', reportKey };
  } catch (err: any) {
    console.error('DOCS MULTI-AGENT CRASH:', err?.message);
    return { agent: 'docs', status: 'error', error: err?.message };
  } finally {
    if (extractPath && existsSync(extractPath)) {
